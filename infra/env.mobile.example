# apps/mobile/.env  (loaded via expo-constants / eas.json)
# For EAS builds, set these as EAS Secrets instead of committing

EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/v1
EXPO_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Deep link scheme (registered in app.json)
EXPO_PUBLIC_APP_SCHEME=rentapp

# Socket.io
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
