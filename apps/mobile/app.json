{
  "expo": {
    "name": "Quản Lý Cho Thuê",
    "slug": "rentapp",
    "version": "1.0.0",
    "scheme": "rentapp",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rentapp.vn",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Chụp ảnh phòng và yêu cầu bảo trì",
        "NSPhotoLibraryUsageDescription": "Chọn ảnh từ thư viện",
        "NSMicrophoneUsageDescription": "Ghi video yêu cầu bảo trì"
      }
    },
    "android": {
      "package": "com.rentapp.vn",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "b688848e-1840-42bf-a66b-17d1d1900e2d"
      }
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-image-picker",
        {
          "photosPermission": "Chọn ảnh từ thư viện"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Chụp ảnh và video cho yêu cầu bảo trì"
        }
      ],
      "expo-secure-store"
    ]
  }
}