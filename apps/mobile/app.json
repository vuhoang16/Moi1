{
  "expo": {
    "name": "Quản Lý Cho Thuê",
    "slug": "rentapp",
    "version": "1.0.0",
    "scheme": "rentapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4F72"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rentapp.vn",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Chụp ảnh phòng và yêu cầu bảo trì",
        "NSPhotoLibraryUsageDescription": "Chọn ảnh từ thư viện",
        "NSMicrophoneUsageDescription": "Ghi video yêu cầu bảo trì"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B4F72"
      },
      "package": "com.rentapp.vn",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-image-picker",
        {
          "photosPermission": "Chọn ảnh từ thư viện"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Chụp ảnh và video cho yêu cầu bảo trì"
        }
      ],
      "expo-secure-store"
    ]
  }
}