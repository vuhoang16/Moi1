{
  "cli": {
    "version": ">= 9.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000/v1",
        "EXPO_PUBLIC_SOCKET_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.rentapp.vn/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.rentapp.vn"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.rentapp.vn/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.rentapp.vn"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "nguyenphanvuhoang@gmail.com",
        "ascAppId": "",
        "appleTeamId": ""
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      }
    }
